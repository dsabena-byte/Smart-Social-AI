      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Extraemos el análisis de Gemini\nconst rawText = $json.content.parts[0].text;\nconst cleanText = rawText.replace(/```json/g, '').replace(/```/g, '').trim();\n\ntry {\n  let result = JSON.parse(cleanText);\n  const igData = $node[\"Run an Actor and get dataset\"].json;\n\n  // Marcas y seguidores dinámicos desde Set Config\n  const config = $('Set Config').first().json;\n  const marcas = config.brands.map(b => b.toLowerCase());\n  const seguidores = config.followers || {};\n\n  let owner = (igData.ownerUsername || \"\").toLowerCase().trim();\n  const caption = (igData.caption || \"\").toLowerCase();\n\n  let marcaFinal = \"\";\n  let pilarFinal = result.pilar || \"Otros\";\n\n  // Lógica de identificación de marca\n  if (marcas.includes(owner)) {\n    marcaFinal = owner;\n  } else {\n    pilarFinal = \"Influencer\";\n    // Busca mención de alguna marca en el caption\n    const encontrada = marcas.find(m => caption.includes(m.replace('.', '')));\n    marcaFinal = encontrada || \"Influencer / No Identificado\";\n  }\n\n  // Cálculo de Engagement con seguidores dinámicos\n  const followersCount = seguidores[marcaFinal] || 100000;\n  const eng = (((igData.likesCount || 0) + (igData.commentsCount || 0)) / followersCount * 100).toFixed(2) + \"%\";\n\n  return {\n    marca: marcaFinal,\n    pilar: pilarFinal,\n    fecha: igData.timestamp ? new Date(igData.timestamp).toLocaleDateString('es-AR') : \"Sin fecha\",\n    distribucion: (igData.likesCount > 400) ? \"PAUTA\" : \"ORGÁNICO\",\n    positivo: result.sentimiento?.positivo || 0,\n    negativo: result.sentimiento?.negativo || 0,\n    neutro: result.sentimiento?.neutro || 0,\n    likes: igData.likesCount || 0,\n    comments: igData.commentsCount || 0,\n    engagement: eng,\n    insight: result.insight || \"Sin análisis\",\n    url: igData.url\n  };\n\n} catch (e) {\n  return { marca: \"ERROR\", insight: e.message };\n}"
      },
