        "jsCode": "// Determina la configuración según el trigger (webhook o schedule)\nconst input = $input.first().json;\nconst body = input.body || input;\n\n// Marcas: desde webhook o valores por defecto (demo)\nconst brands = body.brands || ['gafaargentina', 'dreanargentina', 'whirlpoolarg', 'philco.arg', 'electroluxar'];\n\n// Sheet ID: desde webhook o Sheet por defecto (demo)\nconst sheetId = body.sheetId || '1uIt7zeqdU4QcnQC6Fzw0phPWaO1ppiWY68HVVmpUPDg';\n\n// Datos del cliente\nconst clientEmail = body.clientEmail || '';\nconst myBrand = body.myBrand || brands[0];\n\n// Seguidores: desde webhook o valores por defecto\nconst followers = body.followers || {\n  'philcoarg': 50900,\n  'philco.arg': 50900,\n  'electroluxar': 105000,\n  'whirlpoolarg': 149000,\n  'gafaargentina': 161000,\n  'dreanargentina': 139000\n};\n\nreturn [{ brands, sheetId, clientEmail, myBrand, followers }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
