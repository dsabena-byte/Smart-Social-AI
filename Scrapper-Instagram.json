    {
      "parameters": {
        "jsCode": "const items = $input.all(); \nconst marcasMap = {};\n\n// 1. Recorremos todos los datos que vienen del Aggregate\nitems.forEach(item => {\n  const data = item.json.data; \n  \n  data.forEach(post => {\n    // Identificamos la marca por el nombre de usuario del posteo\n    const nombreMarca = post.ownerUsername || post.ownerId || \"Desconocida\"; \n    \n    if (!marcasMap[nombreMarca]) {\n      marcasMap[nombreMarca] = [];\n    }\n\n    // Extraemos los comentarios reales de la gente (Voz del Cliente)\n    if (post.latestComments && Array.isArray(post.latestComments)) {\n      post.latestComments.forEach(c => {\n        if (c.text) marcasMap[nombreMarca].push(c.text);\n      });\n    }\n  });\n});\n\n// 2. Devolvemos un item independiente por cada marca encontrada\nreturn Object.keys(marcasMap).map(m => {\n  return {\n    MARCA: m, // Nombre limpio de la marca/cuenta\n    all_text: marcasMap[m].join(' '),\n    RED_SOCIAL: \"Instagram\",\n    CANTIDAD_COMENTARIOS: marcasMap[m].length\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
