      "id": "1696fd8f-9073-4b4b-9815-6908467313b4",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Capturamos el texto de la IA\nconst rawText = $json.content.parts[0].text;\n\n// 2. Limpiamos cualquier bloque de código markdown (```json ... ```)\nconst cleanJson = rawText.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n  // 3. Parseamos el JSON\n  const data = JSON.parse(cleanJson);\n\n  // 4. Si Gemini devolvió un Array [{}], extraemos el primer objeto\n  // para que n8n no se confunda con estructuras anidadas\n  return Array.isArray(data) ? data[0] : data;\n\n} catch (error) {\n  // 5. Si falla el parseo, devolvemos un objeto de error legible\n  return {\n    error: \"No se pudo parsear el JSON de la IA\",\n    raw_received: cleanJson.substring(0, 100) // Solo los primeros 100 caracteres\n  };\n}"
      },
