        "emailType": "html",
        "message": "=<!DOCTYPE html><html><body style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f7f7f8;margin:0;padding:40px 20px\">\n<div style=\"max-width:560px;margin:0 auto;background:#fff;border-radius:16px;overflow:hidden;border:1px solid #e0e0e5\">\n  <div style=\"background:#111112;padding:28px 36px\">\n    <div style=\"font-size:1.2rem;font-weight:700;color:#fff\">tomb<span style=\"color:#0057ff\">ai</span>o</div>\n  </div>\n  <div style=\"padding:40px 36px\">\n    <h1 style=\"font-size:1.4rem;color:#111112;margin:0 0 20px\">🔔 Nuevo reporte listo para aprobar</h1>\n    <table style=\"width:100%;border-collapse:collapse;margin-bottom:24px\">\n      <tr><td style=\"padding:6px 0;color:#6b6b75;font-size:.9rem\">Cliente</td><td style=\"padding:6px 0;font-weight:600;color:#111112\">{{ $('Validate Input').first().json.nombre }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b6b75;font-size:.9rem\">Email</td><td style=\"padding:6px 0;color:#111112\">{{ $('Validate Input').first().json.email }}</td></tr>\n      <tr><td style=\"padding:6px 0;color:#6b6b75;font-size:.9rem\">Plan</td><td style=\"padding:6px 0;font-weight:600;color:#0057ff\">{{ $('Validate Input').first().json.plan }}</td></tr>\n    </table>\n    <a href=\"{{ $('Extract Sheet ID').first().json.dashboardUrl }}\" style=\"display:inline-block;background:#111112;color:#fff;text-decoration:none;font-weight:600;padding:12px 28px;border-radius:8px;font-size:.95rem;margin-bottom:12px\">Ver dashboard →</a>\n    <br>\n    <a href=\"{{ $execution.resumeUrl }}\" style=\"display:inline-block;background:#0057ff;color:#fff;text-decoration:none;font-weight:600;padding:12px 28px;border-radius:8px;font-size:.95rem;margin-top:8px\">✅ Aprobar y enviar al cliente →</a>\n    <p style=\"color:#9f9fa8;font-size:.8rem;margin:24px 0 0\">Al hacer clic en Aprobar, el email con el dashboard se enviará automáticamente al cliente.</p>\n  </div>\n</div>\n</body></html>",
        "options": {}
      },
