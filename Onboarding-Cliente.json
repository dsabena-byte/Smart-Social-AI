        "body": "={{ JSON.stringify({ from: 'tombaio <hola@tombaio.com>', to: [$('Validate Input').first().json.email], subject: $('Validate Input').first().json.plan === 'basic' ? 'Tu Reporte Inicial de tombaio está listo 🎯' : 'Tu Dashboard tombaio está listo 🎯', html: '<!DOCTYPE html><html><body style=\"font-family:-apple-system,BlinkMacSystemFont,\\'Segoe UI\\',sans-serif;background:#f7f7f8;margin:0;padding:40px 20px\"><div style=\"max-width:560px;margin:0 auto;background:#fff;border-radius:16px;overflow:hidden;border:1px solid #e0e0e5\"><div style=\"background:#111112;padding:28px 36px\"><div style=\"font-size:1.2rem;font-weight:700;color:#fff\">tomb<span style=\"color:#0057ff\">ai</span>o</div></div><div style=\"padding:40px 36px\"><h1 style=\"font-size:1.5rem;color:#111112;margin:0 0 16px\">' + ($('Validate Input').first().json.plan === 'basic' ? 'Tu Reporte Inicial está listo' : 'Tu Dashboard está listo') + ' 🎯</h1><p style=\"color:#6b6b75;line-height:1.7;margin:0 0 24px\">Hola ' + $('Validate Input').first().json.nombre + ', analizamos todo el contenido de tu categoría. Encontrás los insights más importantes en tu dashboard:</p><a href=\"' + $('Extract Sheet ID').first().json.dashboardUrl + '\" style=\"display:inline-block;background:#0057ff;color:#fff;text-decoration:none;font-weight:600;padding:14px 32px;border-radius:8px;font-size:1rem\">Ver mi ' + ($('Validate Input').first().json.plan === 'basic' ? 'Reporte Inicial' : 'Dashboard') + ' →</a><p style=\"color:#9f9fa8;font-size:.85rem;margin:28px 0 0;line-height:1.6\">¿Dudas o preguntas? Respondé este email o escribinos a <a href=\"mailto:hola@tombaio.com\" style=\"color:#0057ff\">hola@tombaio.com</a></p></div><div style=\"background:#f7f7f8;padding:20px 36px;border-top:1px solid #e0e0e5\"><p style=\"color:#9f9fa8;font-size:.75rem;margin:0\">tombaio · Inteligencia competitiva para redes sociales · <a href=\"https://www.tombaio.com\" style=\"color:#9f9fa8\">tombaio.com</a></p></div></div></body></html>' }) }}",
